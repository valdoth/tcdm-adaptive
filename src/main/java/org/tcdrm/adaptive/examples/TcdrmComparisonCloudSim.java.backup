package org.tcdrm.adaptive.examples;

import org.tcdrm.adaptive.rl.*;
import org.tcdrm.adaptive.gateway.Py4JGateway;
import org.knowm.xchart.*;
import org.knowm.xchart.style.Styler;
import org.knowm.xchart.style.markers.SeriesMarkers;

import java.awt.*;
import java.io.IOException;
import java.util.*;
import java.util.List;

/**
 * Comparaison Complète avec CloudSim (3 approches):
 * 1. Q-Learning Java (entraîné en Java)
 * 2. Q-Learning Python (entraîné en Python, chargé via Py4J)
 * 3. TCDRM Statique (seuils fixes - baseline)
 * 
 * Génère des graphes comparatifs pour validation scientifique
 * Note: Py4J est NÉCESSAIRE pour charger les modèles Python
 */
public class TcdrmComparisonCloudSim {
    
    private static final String OUTPUT_DIR = "results/cloudsim_comparison/";
    private static Py4JGateway gateway;
    
    public static void main(String[] args) throws IOException {
        System.out.println("=".repeat(80));
        System.out.println("COMPARAISON COMPLÈTE: 3 Approches (Java QL, Python QL, Statique)");
        System.out.println("=".repeat(80));
        System.out.println();
        
        // Démarrer le Gateway Py4J (architecture rl-cloudsimplus-greenscheduling)
        System.out.println(" Démarrage du Gateway Py4J...");
        gateway = new Py4JGateway();
        gateway.start();
        
        System.out.println();
        System.out.println(" En attente de la connexion Python...");
        System.out.println("   Le script Python doit se connecter et enregistrer la Q-table");
        System.out.println("=".repeat(80));
        System.out.println();
        
        // Attendre que Python enregistre son modèle
        boolean pythonReady = gateway.waitForPythonModel(60);
        
        if (pythonReady) {
            System.out.println(" Modèle Python enregistré et prêt!");
        } else {
            System.out.println("  Python non connecté - comparaison sans Python QL");
        }
        System.out.println();
        
        // Paramètres de simulation
        double dataGbR1 = 5.3;
        double dataGbR2 = 11.9;
        Long seed = 42L;
        
        // Créer le répertoire de sortie
        new java.io.File(OUTPUT_DIR).mkdirs();
        
        System.out.println(">>> Scénarios à comparer:");
        System.out.println("  - R1: Requête Simple (5.3 GB)");
        System.out.println("  - R2: Requête Complexe (11.9 GB)");
        System.out.println();
        
        // Comparer pour R1
        System.out.println("=== COMPARAISON R1 (5.3 GB) ===");
        compareAllApproaches("R1", dataGbR1, seed);
        
        System.out.println();
        
        // Comparer pour R2
        System.out.println("=== COMPARAISON R2 (11.9 GB) ===");
        compareAllApproaches("R2", dataGbR2, seed);
        
        System.out.println();
        System.out.println("=".repeat(80));
        System.out.println("✅ COMPARAISON TERMINÉE");
        System.out.println("=".repeat(80));
        System.out.println("Graphes sauvegardés dans: " + OUTPUT_DIR);
    }
    
    /**
     * Compare toutes les approches pour un scénario donné
     */
    private static void compareAllApproaches(String queryId, double dataGb, Long seed) throws IOException {
        
        // 1. Q-Learning Java (baseline RL)
        System.out.println("\n>>> 1. Q-Learning Java (entraîné en Java)");
        ComparisonResult javaQLResult = runJavaQLearning(dataGb, seed);
        
        // 2. Q-Learning Python (via Py4J)
        System.out.println("\n>>> 2. Q-Learning Python (entraîné en Python, chargé via Py4J)");
        ComparisonResult pythonQLResult = runPythonQLearning(dataGb, seed, queryId);
        
        // 3. TCDRM Statique (baseline seuils fixes)
        System.out.println("\n>>> 3. TCDRM Statique (seuils fixes)");
        ComparisonResult staticResult = runStaticTcdrm(dataGb, seed);
        
        // 4. Afficher les résultats comparatifs
        System.out.println("\n" + "=".repeat(70));
        System.out.println("RÉSULTATS COMPARATIFS - " + queryId);
        System.out.println("=".repeat(70));
        
        printComparisonTable(javaQLResult, pythonQLResult, staticResult);
        
        // 5. Générer les graphes
        System.out.println("\n>>> Génération des graphes comparatifs...");
        generateComparisonGraphs(queryId, javaQLResult, pythonQLResult, staticResult);
        
        System.out.println("✅ Comparaison " + queryId + " terminée");
    }
    
    /**
     * Exécute Q-Learning Java
     */
    private static ComparisonResult runJavaQLearning(double dataGb, Long seed) {
        TcdrmEnvironment env = new TcdrmEnvironment(dataGb);
        
        // Entraîner rapidement
        QLearningAgent agent = new QLearningAgent(env, 0.1, 0.95, 1.0, 0.995, 0.01);
        System.out.println("  Entraînement Q-Learning Java (500 épisodes)...");
        agent.train(500, seed);
        
        // Évaluer
        System.out.println("  Évaluation...");
        return evaluateQLearningAgent(env, agent, "Q-Learning Java", seed);
    }
    
    /**
     * Exécute Q-Learning Python (via Py4J Gateway)
     */
    private static ComparisonResult runPythonQLearning(double dataGb, Long seed, String queryId) {
        TcdrmEnvironment env = new TcdrmEnvironment(dataGb);
        
        // Vérifier si le modèle Python est enregistré via Py4J
        boolean modelReady = gateway != null && gateway.getPythonAgent() != null && gateway.getPythonAgent().isModelLoaded();
        
        if (!modelReady) {
            System.err.println("  ❌ Modèle Python non connecté via Py4J");
            ComparisonResult result = new ComparisonResult();
            result.name = "Q-Learning Python (NON CONNECTÉ)";
            result.totalReward = 0.0;
            result.totalCost = 0.0;
            result.avgLatency = 0.0;
            result.slaCompliance = 0.0;
            result.budgetRemaining = 0.0;
            result.latencies = new ArrayList<>();
            result.costs = new ArrayList<>();
            result.replicas = new ArrayList<>();
            result.statistics = "Non connecté";
            return result;
        }
        
        // Créer la politique avec l'agent Python enregistré via Py4J
        PythonQLearningPolicy policy = new PythonQLearningPolicy(gateway.getPythonAgent());
        System.out.println("  ✅ Modèle Python connecté via Py4J. Évaluation...");
        
        // Évaluer avec le modèle Python
        TcdrmState state = env.reset(seed);
        double totalReward = 0.0;
        double totalCost = 0.0;
        int slaViolations = 0;
        int steps = 0;
        
        List<Double> latencies = new ArrayList<>();
        List<Double> costs = new ArrayList<>();
        List<Integer> replicas = new ArrayList<>();
        
        while (true) {
            // Choisir l'action avec le modèle Python
            TcdrmAction action = policy.chooseAction(state);
            
            // Exécuter
            Environment.StepResult<TcdrmState> result = env.step(action);
            
            totalReward += result.getReward();
            
            // Calculer le coût du step
            double stepCost = calculateStepCost(env, action, env.getCurrentReplicaCount(), dataGb);
            totalCost += stepCost;
            
            double latency = env.getCurrentLatency();
            latencies.add(latency);
            costs.add(totalCost);
            replicas.add(env.getCurrentReplicaCount());
            
            if (latency > 150.0) slaViolations++;
            steps++;
            
            state = result.getNextState();
            if (result.isDone()) break;
        }
        
        double slaCompliance = 1.0 - ((double) slaViolations / steps);
        
        ComparisonResult compResult = new ComparisonResult();
        compResult.name = "Q-Learning Python";
        compResult.totalReward = totalReward;
        compResult.totalCost = totalCost;
        compResult.avgLatency = latencies.stream().mapToDouble(d -> d).average().orElse(0);
        compResult.slaCompliance = slaCompliance;
        compResult.budgetRemaining = env.getCurrentBudget();
        compResult.latencies = latencies;
        compResult.costs = costs;
        compResult.replicas = replicas;
        compResult.statistics = policy.toString();
        
        return compResult;
    }
    
    /**
     * Exécute TCDRM Statique
     */
    private static ComparisonResult runStaticTcdrm(double dataGb, Long seed) {
        TcdrmEnvironment env = new TcdrmEnvironment(dataGb);
        StaticTcdrmPolicy policy = new StaticTcdrmPolicy();
        
        System.out.println("  Évaluation politique statique...");
        
        // Évaluer
        TcdrmState state = env.reset(seed);
        double totalReward = 0.0;
        double totalCost = 0.0;
        int slaViolations = 0;
        int steps = 0;
        
        List<Double> latencies = new ArrayList<>();
        List<Double> costs = new ArrayList<>();
        List<Integer> replicas = new ArrayList<>();
        
        while (true) {
            // Obtenir les informations pour les seuils
            double budgetRatio = env.getCurrentBudget() / 100.0;
            double latency = env.getCurrentLatency();
            int accessCount = env.getAccessCount();
            int currentReplicas = env.getCurrentReplicaCount();
            
            // Choisir l'action avec la politique statique
            TcdrmAction action = policy.chooseAction(budgetRatio, latency, 
                                                     accessCount, currentReplicas);
            
            // Exécuter
            Environment.StepResult<TcdrmState> result = env.step(action);
            
            totalReward += result.getReward();
            
            // Calculer le coût du step
            double stepCost = calculateStepCost(env, action, currentReplicas, dataGb);
            totalCost += stepCost;
            
            latencies.add(latency);
            costs.add(totalCost);
            replicas.add(currentReplicas);
            
            if (latency > 150.0) slaViolations++;
            steps++;
            
            state = result.getNextState();
            if (result.isDone()) break;
        }
        
        double slaCompliance = 1.0 - ((double) slaViolations / steps);
        
        ComparisonResult compResult = new ComparisonResult();
        compResult.name = "TCDRM Statique";
        compResult.totalReward = totalReward;
        compResult.totalCost = totalCost;
        compResult.avgLatency = latencies.stream().mapToDouble(d -> d).average().orElse(0);
        compResult.slaCompliance = slaCompliance;
        compResult.budgetRemaining = env.getCurrentBudget();
        compResult.latencies = latencies;
        compResult.costs = costs;
        compResult.replicas = replicas;
        compResult.statistics = policy.getStatistics();
        
        return compResult;
    }
    
    /**
     * Évalue un agent Q-Learning
     */
    private static ComparisonResult evaluateQLearningAgent(TcdrmEnvironment env, QLearningAgent agent, 
                                                           String name, Long seed) {
        TcdrmState state = env.reset(seed);
    
    compResult.name = name;
    compResult.totalReward = totalReward;
    compResult.totalCost = totalCost;
    compResult.avgLatency = compResult.latencies.stream().mapToDouble(d -> d).average().orElse(0);
    compResult.slaCompliance = slaCompliance;
    compResult.budgetRemaining = env.getCurrentBudget();
    compResult.statistics = "Q-Learning";
     * Calcule le coût d'un step (simplifié)
     */
    private static double calculateStepCost(TcdrmEnvironment env, TcdrmAction action, 
                                           int replicas, double dataGb) {
        double cost = 0.0;
        
        // Coût de bande passante (simplifié)
        if (replicas > 0) {
            cost += 0.002 * dataGb; // Intra-DC
        } else {
            cost += 0.10 * dataGb;  // Inter-provider
        }
        
        // Coût de stockage
        cost += replicas * dataGb * (0.02 / 720.0);
        
        // Coût de création de réplica
        if (action == TcdrmAction.CREATE_REPLICA) {
            cost += 0.10 * dataGb;
        }
        
        return cost;
    }
    
    /**
     * Affiche un tableau comparatif (3 approches)
     */
    private static void printComparisonTable(ComparisonResult javaQL, ComparisonResult pythonQL, ComparisonResult staticTcdrm) {
        System.out.println(String.format("%-25s | %15s | %15s | %15s", 
            "Métrique", "Java Q-Learning", "Python Q-Learning", "TCDRM Statique"));
        System.out.println("-".repeat(80));
        
        System.out.println(String.format("%-25s | %15.2f | %15.2f | %15.2f",
            "Récompense Totale", javaQL.totalReward, pythonQL.totalReward, staticTcdrm.totalReward));
        
        System.out.println(String.format("%-25s | %15.2f | %15.2f | %15.2f",
            "Coût Total ($)", javaQL.totalCost, pythonQL.totalCost, staticTcdrm.totalCost));
        
        System.out.println(String.format("%-25s | %15.2f | %15.2f | %15.2f",
            "Latence Moyenne (ms)", javaQL.avgLatency, pythonQL.avgLatency, staticTcdrm.avgLatency));
        
        System.out.println(String.format("%-25s | %14.1f%% | %14.1f%% | %14.1f%%",
            "Conformité SLA", javaQL.slaCompliance * 100, pythonQL.slaCompliance * 100, staticTcdrm.slaCompliance * 100));
        
        System.out.println(String.format("%-25s | %15.2f | %15.2f | %15.2f",
            "Budget Restant ($)", javaQL.budgetRemaining, pythonQL.budgetRemaining, staticTcdrm.budgetRemaining));
        
        // Calculer les améliorations
        System.out.println();
        System.out.println("Amélioration vs Statique:");
        
        double costImprovJava = ((staticTcdrm.totalCost - javaQL.totalCost) / staticTcdrm.totalCost) * 100;
        double costImprovPython = ((staticTcdrm.totalCost - pythonQL.totalCost) / staticTcdrm.totalCost) * 100;
        System.out.println(String.format("  Coût Java QL:    %+.1f%%", costImprovJava));
        System.out.println(String.format("  Coût Python QL:  %+.1f%%", costImprovPython));
        
        double slaImprovJava = ((javaQL.slaCompliance - staticTcdrm.slaCompliance) / staticTcdrm.slaCompliance) * 100;
        double slaImprovPython = ((pythonQL.slaCompliance - staticTcdrm.slaCompliance) / staticTcdrm.slaCompliance) * 100;
        System.out.println(String.format("  SLA Java QL:     %+.1f%%", slaImprovJava));
        System.out.println(String.format("  SLA Python QL:   %+.1f%%", slaImprovPython));
    }
    
    /**
     * Génère les graphes comparatifs (3 approches)
     */
    private static void generateComparisonGraphs(String queryId, 
                                                ComparisonResult javaQL,
                                                ComparisonResult pythonQL,
                                                ComparisonResult staticTcdrm) throws IOException {
        
        // Graphe 1: Coût cumulatif
        XYChart costChart = new XYChartBuilder()
            .width(800).height(600)
            .title("Coût Cumulatif - " + queryId)
            .xAxisTitle("Requête")
            .yAxisTitle("Coût Cumulatif ($)")
            .build();
        
        costChart.getStyler().setLegendPosition(Styler.LegendPosition.InsideNE);
        costChart.getStyler().setDefaultSeriesRenderStyle(XYSeries.XYSeriesRenderStyle.Line);
        
        costChart.addSeries("Q-Learning Java", createXData(javaQL.costs.size()), javaQL.costs);
        if (!pythonQL.costs.isEmpty()) {
            costChart.addSeries("Q-Learning Python", createXData(pythonQL.costs.size()), pythonQL.costs);
        }
        costChart.addSeries("TCDRM Statique", createXData(staticTcdrm.costs.size()), staticTcdrm.costs);
        
        BitmapEncoder.saveBitmap(costChart, OUTPUT_DIR + "cost_comparison_" + queryId, BitmapEncoder.BitmapFormat.PNG);
        
        // Graphe 2: Latence
        XYChart latencyChart = new XYChartBuilder()
            .width(800).height(600)
            .title("Latence par Requête - " + queryId)
            .xAxisTitle("Requête")
            .yAxisTitle("Latence (ms)")
            .build();
        
        latencyChart.getStyler().setLegendPosition(Styler.LegendPosition.InsideNE);
        latencyChart.getStyler().setDefaultSeriesRenderStyle(XYSeries.XYSeriesRenderStyle.Line);
        
        latencyChart.addSeries("Q-Learning Java", createXData(javaQL.latencies.size()), javaQL.latencies);
        if (!pythonQL.latencies.isEmpty()) {
            latencyChart.addSeries("Q-Learning Python", createXData(pythonQL.latencies.size()), pythonQL.latencies);
        }
        latencyChart.addSeries("TCDRM Statique", createXData(staticTcdrm.latencies.size()), staticTcdrm.latencies);
        
        // Ligne SLA
        List<Double> slaLine = new ArrayList<>();
        for (int i = 0; i < javaQL.latencies.size(); i++) slaLine.add(150.0);
        XYSeries slaSeries = latencyChart.addSeries("Seuil SLA (150ms)", createXData(slaLine.size()), slaLine);
        slaSeries.setLineStyle(new BasicStroke(2, BasicStroke.CAP_BUTT, BasicStroke.JOIN_MITER, 
                                               10, new float[]{5}, 0));
        slaSeries.setLineColor(Color.RED);
        
        BitmapEncoder.saveBitmap(latencyChart, OUTPUT_DIR + "latency_comparison_" + queryId, BitmapEncoder.BitmapFormat.PNG);
        
        // Graphe 3: Nombre de réplicas
        XYChart replicaChart = new XYChartBuilder()
            .width(800).height(600)
            .title("Nombre de Réplicas - " + queryId)
            .xAxisTitle("Requête")
            .yAxisTitle("Nombre de Réplicas")
            .build();
        
        replicaChart.getStyler().setLegendPosition(Styler.LegendPosition.InsideNE);
        replicaChart.getStyler().setDefaultSeriesRenderStyle(XYSeries.XYSeriesRenderStyle.Step);
        
        replicaChart.addSeries("Q-Learning Java", createXData(javaQL.replicas.size()), javaQL.replicas);
        if (!pythonQL.replicas.isEmpty()) {
            replicaChart.addSeries("Q-Learning Python", createXData(pythonQL.replicas.size()), pythonQL.replicas);
        }
        replicaChart.addSeries("TCDRM Statique", createXData(staticTcdrm.replicas.size()), staticTcdrm.replicas);
        
        BitmapEncoder.saveBitmap(replicaChart, OUTPUT_DIR + "replicas_comparison_" + queryId, BitmapEncoder.BitmapFormat.PNG);
        
        System.out.println("✅ Graphes sauvegardés:");
        System.out.println("   - " + OUTPUT_DIR + "cost_comparison_" + queryId + ".png");
        System.out.println("   - " + OUTPUT_DIR + "latency_comparison_" + queryId + ".png");
        System.out.println("   - " + OUTPUT_DIR + "replicas_comparison_" + queryId + ".png");
    }
    
    /**
     * Crée les données X pour les graphes
     */
    private static List<Integer> createXData(int size) {
        List<Integer> xData = new ArrayList<>();
        for (int i = 0; i < size; i++) {
            xData.add(i);
        }
        return xData;
    }
    
    /**
     * Classe pour stocker les résultats d'une approche
     */
    static class ComparisonResult {
        String name;
        double totalReward;
        double totalCost;
        double avgLatency;
        double slaCompliance;
        double budgetRemaining;
        List<Double> latencies;
        List<Double> costs;
        List<Integer> replicas;
        String statistics;
        
        // Métriques supplémentaires pour les graphes détaillés
        List<Double> cpuUsage;           // Utilisation CPU par step
        List<Double> bandwidthCosts;     // Coût de bande passante par step
        List<Double> cumulativeBwCosts;  // Coût cumulatif de bande passante
        List<Double> responseTimes;      // Temps de réponse par requête
        List<Double> storageUsage;       // Utilisation du stockage
        
        public ComparisonResult() {
            latencies = new ArrayList<>();
            costs = new ArrayList<>();
            replicas = new ArrayList<>();
            cpuUsage = new ArrayList<>();
            bandwidthCosts = new ArrayList<>();
            cumulativeBwCosts = new ArrayList<>();
            responseTimes = new ArrayList<>();
            storageUsage = new ArrayList<>();
        }
    }
}
